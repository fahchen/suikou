# Suikou runtime configuration.
#
# Location: $XDG_CONFIG_HOME/suikou/config.toml
#           (defaults to ~/.config/suikou/config.toml)
#
# Read once at startup by the packaged binary (production only; the dev/test
# servers ignore it). Copy this file to the location above, edit, then restart
# with `suikou stop && suikou start`. Every key is optional: an omitted key uses
# the default noted below. A syntactically invalid file fails startup loudly
# rather than silently reverting to defaults.

# Host used to build absolute URLs (e.g. links the server generates). Set it to
# this machine's Tailscale MagicDNS name so URLs resolve for tailnet peers. The
# server always binds every interface regardless of this value.
# Default: the PHX_HOST environment variable, or "example.com" if unset.
# host = "mybox.tailnet-name.ts.net"

# WebSocket origin check for the Musubi socket.
#   false                      accept any origin
#   ["//host-a", "//host-b"]   allow only these origins ("//host" matches any
#                              scheme/port, so it works for plain HTTP)
# A tailnet peer may connect by raw IP or MagicDNS name interchangeably, so the
# default accepts any origin: appropriate for a single-user app on a private,
# tailscale-authenticated network. Tighten to a list if exposed more widely.
# Default: false.
# check_origin = false

# Which interfaces the server listens on. A preset (raw addresses aren't
# expressible in TOML); both keep this machine reachable on 127.0.0.1.
#   "all"      every interface (reachable over the tailnet)
#   "loopback" 127.0.0.1 only (this machine only; disables tailnet access)
# Default: "all".
# bind = "all"

# Path to the SQLite database file. Override to relocate the database; existing
# data is not moved for you.
# Default: <app support dir>/suikou.db (set by the launcher).
# database_path = "/Users/me/suikou/suikou.db"

# Database connection pool size.
# Default: 5.
# pool_size = 5

# TCP port the server listens on. The launcher reads this to bind, record, and
# probe the daemon, then opens http://localhost:<port>. The PORT environment
# variable, if set, overrides it for a single invocation.
# Default: 47100.
# port = 47100

# Frontend debug overlay: surfaces React render/route errors with a stack-trace
# overlay instead of the graceful default UI. The dev server always has it on;
# this key turns it on for the packaged build.
# Default: false.
# debug = false
